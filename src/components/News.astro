---
import { getCollection, render } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const fmt = new Intl.DateTimeFormat('th-TH', { day: 'numeric', month: 'long', year: 'numeric' });

// เตรียมเนื้อหาเต็มของแต่ละบทความไว้ใช้แสดงใน modal
const rendered = await Promise.all(
  posts.map(async (post) => ({ post, Content: (await render(post)).Content }))
);
---

<section class="section news" id="news">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">News</span>
      <h2 class="section-title">ข่าวสารและกิจกรรม</h2>
      <p>สาระความรู้เรื่องการดูแลผิวหนังและสุขภาพสัตว์เลี้ยง</p>
    </div>

    <div class="news__grid">
      {
        posts.map((post) => (
          <article class="news-card reveal">
            {post.data.image && (
              <div class="news-card__media">
                <img src={post.data.image} alt={post.data.title} loading="lazy" />
              </div>
            )}
            <div class="news-card__body">
              <time class="news-card__date" datetime={post.data.date.toISOString()}>
                {fmt.format(post.data.date)}
              </time>
              <h3 class="news-card__title">{post.data.title}</h3>
              {post.data.excerpt && <p class="news-card__excerpt">{post.data.excerpt}</p>}
              <button class="news-card__link" type="button" data-news-open={post.id}>
                อ่านต่อ →
              </button>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  {/* เนื้อหาเต็มของแต่ละบทความ (ซ่อนไว้) สำหรับนำไปแสดงใน modal */}
  <div class="news-modal__store" hidden>
    {
      rendered.map(({ post, Content }) => (
        <template data-news-template={post.id}>
          <time class="news-modal__date">{fmt.format(post.data.date)}</time>
          <h3 class="news-modal__title">{post.data.title}</h3>
          {post.data.image && (
            <img class="news-modal__cover" src={post.data.image} alt={post.data.title} />
          )}
          <div class="news-modal__body">
            <Content />
          </div>
        </template>
      ))
    }
  </div>
</section>

{/* กล่อง modal ใช้ร่วมกันทุกบทความ */}
<div class="news-modal" id="newsModal" aria-hidden="true">
  <div class="news-modal__backdrop" data-news-close></div>
  <div class="news-modal__dialog" role="dialog" aria-modal="true" aria-label="บทความข่าวสาร">
    <button class="news-modal__close" type="button" data-news-close aria-label="ปิด">×</button>
    <div class="news-modal__content"></div>
  </div>
</div>

<style>
  .news__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.8rem;
  }
  .news-card {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border: 1px solid #eef3f7;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .news-card:hover { transform: translateY(-6px); box-shadow: var(--shadow); }
  .news-card__media { aspect-ratio: 1 / 1; overflow: hidden; background: var(--c-alice); }
  .news-card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .news-card:hover .news-card__media img { transform: scale(1.05); }
  .news-card__body { padding: 1.4rem; display: flex; flex-direction: column; gap: 0.6rem; flex: 1; }
  .news-card__date { color: var(--c-teal); font-weight: 700; font-size: 0.85rem; }
  .news-card__title { font-size: 1.18rem; }
  .news-card__excerpt { color: var(--c-muted); font-size: 0.95rem; flex: 1; }
  .news-card__link {
    align-self: flex-start;
    margin-top: 0.4rem;
    padding: 0;
    background: none;
    border: none;
    font: inherit;
    color: var(--c-primary);
    font-weight: 700;
    cursor: pointer;
    transition: color 0.15s ease, transform 0.15s ease;
  }
  .news-card__link:hover { color: var(--c-secondary); transform: translateX(3px); }

  /* ---------- Modal ---------- */
  .news-modal { position: fixed; inset: 0; z-index: 120; display: none; }
  .news-modal.is-open { display: block; }
  .news-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 43, 73, 0.55);
    backdrop-filter: blur(2px);
    animation: newsFade 0.2s ease;
  }
  .news-modal__dialog {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    width: min(720px, calc(100% - 2rem));
    max-height: 88vh;
    overflow-y: auto;
    margin: 6vh auto;
    background: #fff;
    border-radius: 22px;
    padding: clamp(1.4rem, 4vw, 2.6rem);
    box-shadow: 0 30px 70px rgba(8, 43, 73, 0.3);
    animation: newsPop 0.24s ease;
  }
  .news-modal__close {
    position: sticky;
    top: 0;
    align-self: flex-end;
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    margin-bottom: -1.2rem;
    border: none;
    border-radius: 50%;
    background: var(--c-alice);
    color: var(--c-navy);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .news-modal__close:hover { background: var(--c-primary); color: #fff; }
  .news-modal__content { color: var(--c-text); }
  .news-modal__date { display: block; color: var(--c-teal); font-weight: 700; font-size: 0.9rem; }
  .news-modal__title { font-size: clamp(1.4rem, 3.4vw, 2rem); margin-block: 0.4rem 1.2rem; }
  .news-modal__cover {
    width: 100%;
    max-width: 420px;
    border-radius: 16px;
    box-shadow: var(--shadow-sm);
    margin-bottom: 1.6rem;
  }
  .news-modal__body :global(p) { margin-bottom: 1.1rem; }
  .news-modal__body :global(ul) { margin-bottom: 1.1rem; display: grid; gap: 0.4rem; }
  .news-modal__body :global(strong) { color: var(--c-navy); }

  @keyframes newsFade { from { opacity: 0; } to { opacity: 1; } }
  @keyframes newsPop {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .news-modal__backdrop, .news-modal__dialog { animation: none; }
  }
</style>

<script>
  const modal = document.getElementById('newsModal');
  if (modal) {
    const content = modal.querySelector('.news-modal__content');
    const dialog = modal.querySelector('.news-modal__dialog');
    let lastFocus = null;

    const openModal = (id) => {
      const tpl = document.querySelector(`[data-news-template="${id}"]`);
      if (!tpl || !content) return;
      content.replaceChildren(tpl.content.cloneNode(true));
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      if (dialog) dialog.scrollTop = 0;
      lastFocus = document.activeElement;
      const closeBtn = modal.querySelector('.news-modal__close');
      if (closeBtn) closeBtn.focus();
    };

    const closeModal = () => {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (content) content.replaceChildren();
      if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
    };

    document.querySelectorAll('[data-news-open]').forEach((btn) => {
      btn.addEventListener('click', () => openModal(btn.getAttribute('data-news-open')));
    });
    modal.querySelectorAll('[data-news-close]').forEach((el) => {
      el.addEventListener('click', closeModal);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
    });
  }
</script>

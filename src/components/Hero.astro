---
import site from '../data/site.json';
---

<section class="hero" id="top">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="container hero__inner">
    <div class="hero__text reveal">
      <span class="eyebrow">Caring for pets, Enhancing lives</span>
      <h1 class="hero__title">
        ดูแลผิวหนังและสุขภาพสัตว์เลี้ยง<br />
        <span class="hero__title-accent">ด้วยความเชี่ยวชาญจากทีมสัตวแพทย์</span>
      </h1>
      <p class="hero__lead">
        VetVitallist (VVL) ผู้เชี่ยวชาญเวชภัณฑ์สัตว์เลี้ยงกว่า 10 ปี
        พัฒนาผลิตภัณฑ์คุณภาพเพื่อส่งเสริมคุณภาพชีวิตของคนและสัตว์เลี้ยง
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="#products">ดูผลิตภัณฑ์</a>
        <a class="btn btn--ghost" href="#contact">ติดต่อเรา</a>
      </div>
    </div>

    <div class="hero__media reveal">
      <img
        src="/images/wvvl-only-main-box-set-05.png"
        alt="ผลิตภัณฑ์ VetVitallist"
        width="900"
        height="330"
        fetchpriority="high"
      />
    </div>
  </div>

  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {[...site.features, ...site.features].map((f) => (
        <span class="marquee__item">
          <img src={f.icon} alt="" width="22" height="22" />
          {f.label}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(160deg, var(--c-sky-soft) 0%, #ffffff 60%);
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 60% at 85% 10%, rgba(28, 180, 170, 0.16), transparent 70%),
      radial-gradient(50% 50% at 5% 90%, rgba(0, 67, 113, 0.1), transparent 70%);
    pointer-events: none;
  }
  .hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    align-items: center;
    gap: 3rem;
    padding-block: clamp(48px, 7vw, 92px);
  }
  .hero__title {
    font-size: clamp(2rem, 4.6vw, 3.35rem);
    margin-block: 0.4rem 1.1rem;
  }
  .hero__title-accent { color: var(--c-primary); }
  .hero__lead {
    font-size: 1.1rem;
    color: var(--c-muted);
    max-width: 34rem;
    margin-bottom: 1.9rem;
  }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 0.9rem; }
  .hero__media img {
    width: 100%;
    filter: drop-shadow(0 30px 45px rgba(8, 43, 73, 0.18));
    animation: floaty 6s ease-in-out infinite;
  }
  @keyframes floaty {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }

  .marquee {
    position: relative;
    overflow: hidden;
    background: var(--c-primary);
    padding-block: 0.85rem;
  }
  .marquee__track {
    display: flex;
    gap: 3rem;
    width: max-content;
    animation: scroll 26s linear infinite;
  }
  .marquee__item {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: #fff;
    font-weight: 500;
    white-space: nowrap;
    opacity: 0.95;
  }
  .marquee__item img { filter: brightness(0) invert(1); }
  @keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (max-width: 860px) {
    .hero__inner { grid-template-columns: 1fr; text-align: center; }
    .hero__lead { margin-inline: auto; }
    .hero__actions { justify-content: center; }
    .hero__media { order: -1; max-width: 460px; margin-inline: auto; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__media img, .marquee__track { animation: none; }
  }
</style>
